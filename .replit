# HOSTING ONLY — do not edit app code in this Repl.
# Develop in Cursor → push to GitHub → Pull here → Run/Deploy.
# See replit.md and REPLIT_SETUP.txt.

modules = ["nodejs-20", "web"]

run = "npm run dev"

entrypoint = "index.html"

hidden = [".config", "package-lock.json"]

[deployment]
deploymentTarget = "static"
build = ["sh", "-c", "npm install && npm run build"]
publicDir = "dist"

[[deployment.rewrites]]
from = "/*"
to = "/index.html"

[[ports]]
localPort = 5173
externalPort = 80

[nix]
channel = "stable-24_05"
