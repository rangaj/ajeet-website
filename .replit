# HOSTING ONLY — do not edit app code in this Repl.
# Develop in Cursor → push to GitHub → Pull here → Run/Deploy.
# See replit.md and REPLIT_SETUP.txt.
#
# Replit Publishing has no type picker for this Repl — it uses Autoscale.
# Config below is Autoscale-only: build dist, then serve on $PORT.

modules = ["nodejs-20", "web"]

run = "npm run dev"

entrypoint = "index.html"

hidden = [".config", "package-lock.json"]

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "rm -f package-lock.json && npm install && rm -rf dist && export VITE_BUILD_ID=$(node scripts/resolve-build-id.mjs) && npm run build"]
run = ["sh", "-c", "node scripts/serve-dist.mjs"]

[nix]
channel = "stable-24_05"
